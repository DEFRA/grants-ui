{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExampleGrantWithAuthApplicationPayload",
  "type": "object",
  "properties": {
    "yesNoField": { "type": "boolean" },
    "autocompleteField": { "type": "string" },
    "radiosField": { "type": "string" },
    "checkboxesField": { "type": "array", "items": { "type": "string" } },
    "numberFieldValidation": { "type": "number" },
    "numberFieldRouting": { "type": "number" },
    "datePartsField__day": { "type": "number" },
    "datePartsField__month": { "type": "number" },
    "datePartsField__year": { "type": "number" },
    "monthYearField__month": { "type": "number" },
    "monthYearField__year": { "type": "number" },
    "selectField": { "type": "string" },
    "multilineTextField": { "type": "string" },
    "emailAddressField": { "type": "string", "format": "email" },
    "telephoneNumberField": { "type": "string" },
    "ukAddressField__addressLine1": { "type": "string" },
    "ukAddressField__addressLine2": { "type": ["string", "null"] },
    "ukAddressField__town": { "type": "string" },
    "ukAddressField__county": { "type": ["string", "null"] },
    "ukAddressField__postcode": { "type": "string" },
    "eastingNorthingField__easting": { "type": "number" },
    "eastingNorthingField__northing": { "type": "number" },
    "osGridRefField": { "type": "string" },
    "nationalGridFieldNumberField": { "type": "string" },
    "latLongField__latitude": { "type": "number" },
    "latLongField__longitude": { "type": "number" },
    "geospatialField": {
      "type": "array",
      "minItems": 1,
      "description": "GeoJSON-style feature objects captured by the GeospatialField component"
    },
    "hiddenField": { "type": "string" },
    "projectName": { "type": "string" },
    "projectDescription": { "type": "string" },
    "projectBudget": { "type": "number" },
    "repeatItems": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" },
      "description": "RepeatPage items, each holding repeatItemName (string) and repeatItemAmount (number)"
    },
    "landParcels": { "type": "array", "items": { "type": "string" } },
    "detailsConfirmedAt": { "type": "string", "format": "date-time" },
    "applicant": {
      "type": "object",
      "description": "Business and customer details sourced from the DAL via the check-details controller",
      "properties": {
        "business": {
          "type": "object",
          "properties": {
            "reference": { "type": ["string", "null"] },
            "name": { "type": ["string", "null"] },
            "vat": { "type": ["string", "null"] },
            "email": {
              "type": "object",
              "properties": {
                "address": { "type": ["string", "null"] }
              }
            },
            "phone": {
              "type": "object",
              "properties": {
                "mobile": { "type": ["string", "null"] },
                "landline": { "type": ["string", "null"] }
              }
            },
            "address": {
              "type": "object",
              "properties": {
                "line1": { "type": ["string", "null"] },
                "line2": { "type": ["string", "null"] },
                "line3": { "type": ["string", "null"] },
                "line4": { "type": ["string", "null"] },
                "line5": { "type": ["string", "null"] },
                "street": { "type": ["string", "null"] },
                "city": { "type": ["string", "null"] },
                "postalCode": { "type": ["string", "null"] },
                "uprn": { "type": ["string", "null"] },
                "county": { "type": ["string", "null"] },
                "buildingName": { "type": ["string", "null"] },
                "buildingNumberRange": { "type": ["string", "null"] },
                "dependentLocality": { "type": ["string", "null"] },
                "doubleDependentLocality": { "type": ["string", "null"] },
                "flatName": { "type": ["string", "null"] },
                "pafOrganisationName": { "type": ["string", "null"] }
              }
            }
          }
        },
        "customer": {
          "type": "object",
          "properties": {
            "name": {
              "type": "object",
              "properties": {
                "title": { "type": ["string", "null"] },
                "first": { "type": ["string", "null"] },
                "middle": { "type": ["string", "null"] },
                "last": { "type": ["string", "null"] }
              }
            }
          }
        },
        "countyParishHoldings": { "type": ["string", "null"] }
      }
    }
  },
  "required": [
    "yesNoField",
    "autocompleteField",
    "radiosField",
    "checkboxesField",
    "numberFieldValidation",
    "numberFieldRouting",
    "datePartsField__day",
    "datePartsField__month",
    "datePartsField__year",
    "monthYearField__month",
    "monthYearField__year",
    "selectField",
    "multilineTextField",
    "emailAddressField",
    "telephoneNumberField",
    "ukAddressField__addressLine1",
    "ukAddressField__town",
    "ukAddressField__postcode",
    "eastingNorthingField__easting",
    "eastingNorthingField__northing",
    "osGridRefField",
    "nationalGridFieldNumberField",
    "latLongField__latitude",
    "latLongField__longitude",
    "geospatialField",
    "projectName",
    "projectBudget",
    "repeatItems",
    "landParcels"
  ]
}
