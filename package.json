{
  "name": "grants-ui",
  "version": "0.0.0",
  "description": "Grants UI",
  "sideEffects": [
    "src/client/javascripts/cookie-consent.js",
    "src/server/cookies/cookie-preferences.js",
    "src/server/cookies/append-return-url.js"
  ],
  "main": ".server/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "build": "run-s build:frontend build:server",
    "build:frontend": "NODE_ENV=production webpack",
    "build:server": "NODE_ENV=production babel --delete-dir-on-start --ignore \"**/*.test.js\" --ignore \"**/test-helpers\" --ignore \"**/__mocks__\" --copy-files --no-copy-ignored --out-dir ./.server ./src",
    "dev": "run-p frontend:watch server:watch",
    "dev:debug": "run-p frontend:watch server:debug",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down --remove-orphans",
    "docker:debug": "docker compose stop grants-ui && docker compose run --service-ports --name grants-ui-debug --rm grants-ui npm run dev:debug",
    "docker:cycle-ui": "docker compose up -d --force-recreate grants-ui",
    "docker:reset": "docker compose down --volumes --remove-orphans --rmi local",
    "docker:ha:up": "docker compose -f compose.yml -f compose.ha.yml up -d --scale grants-ui=2 --scale grants-ui-backend=2",
    "docker:ha:down": "docker compose -f compose.yml -f compose.ha.yml down --remove-orphans",
    "docker:landgrants:up": "docker compose -f compose.yml -f compose.land-grants.yml up -d",
    "docker:landgrants:down": "docker compose -f compose.yml -f compose.land-grants.yml down --remove-orphans",
    "docker:landgrants:ha:up": "docker compose -f compose.yml -f compose.ha.yml -f compose.land-grants.yml up -d --scale grants-ui=2 --scale grants-ui-backend=2",
    "docker:landgrants:ha:down": "docker compose -f compose.yml -f compose.ha.yml -f compose.land-grants.yml down --remove-orphans",
    "docker:rebuild": "docker compose build",
    "format": "prettier --write \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js,contract.test.js}\" \"!.stryker-tmp/**\"",
    "json:format:single": "npx prettier --write",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.{js,cjs,md,json,config.js,test.js}\" \"!.stryker-tmp/**\"",
    "frontend:watch": "NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run format:check && npm run lint && npm test",
    "postinstall": "npm run setup:husky && npm run build",
    "lint": "run-s lint:js lint:scss lint:types",
    "lint:fix": "eslint . --fix",
    "lint:js": "eslint --cache --cache-strategy content .",
    "lint:types": "tsc --build tsconfig.json",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "gas-status:set": "f() { curl -X PUT http://localhost:1080/mockserver/expectation -H 'Content-Type: application/json' -d '{\"id\":\"gas-application-status-200\",\"priority\":0,\"httpRequest\":{\"method\":\"GET\",\"path\":\"/grants/.*/applications/.*/status\"},\"httpResponse\":{\"statusCode\":200,\"body\":{\"status\":\"'\"$1\"'\"}}}'; }; f",
    "gas-status:get": "curl -s -X PUT 'http://localhost:1080/mockserver/retrieve?type=ACTIVE_EXPECTATIONS' -H 'Content-Type: application/json' -d '{\"path\":\"/grants/.*/applications/.*/status\"}' | jq -r '.[] | select(.id == \"gas-application-status-200\") | .httpResponse.body.status // \"RECEIVED (default)\"'",
    "postversion": "git add package.json package-lock.json && git commit -m $npm_package_version",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --config vitest.unit.config.js",
    "test:stryker": "vitest run --config vitest.stryker.config.js",
    "test:contracts": "vitest run src/contracts",
    "test:acceptance": "./tools/run-acceptance-tests.sh",
    "test:performance": "./tools/run-performance-tests.sh",
    "test:all": "./tools/run-all-tests.sh",
    "test:watch": "vitest --watch",
    "server:watch": "nodemon --ext js,mjs,json,njk,html --exec tsx --enable-source-maps ./src",
    "server:debug": "nodemon --ext js,mjs,json,njk,html,yaml --exec tsx --enable-source-maps --inspect=0.0.0.0:9229 ./src",
    "snyk-test": "snyk test",
    "snyk-monitor": "snyk monitor",
    "prestart": "npm run build",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "unseal:cookie": "node ./tools/unseal-cookie.js"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "overrides": {
    "tmp": "0.2.4",
    "node-jose": {
      "node-forge": "1.3.2"
    },
    "babel-plugin-module-resolver": {
      "minimatch": "10.2.3"
    },
    "serialize-javascript": "7.0.4",
    "svgo": "4.0.1",
    "underscore": "1.13.8",
    "liquidjs": "10.25.0"
  },
  "dependencies": {
    "@babel/runtime": "7.28.6",
    "@defra/forms-engine-plugin": "4.1.3",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/bell": "13.1.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/cookie": "12.0.1",
    "@hapi/crumb": "9.0.1",
    "@hapi/h2o2": "10.0.4",
    "@hapi/hapi": "21.4.6",
    "@hapi/inert": "7.1.0",
    "@hapi/jwt": "3.2.3",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "accessible-autocomplete": "3.0.1",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "aws-embedded-metrics": "4.2.1",
    "babel-plugin-module-resolver": "5.0.2",
    "convict": "6.2.4",
    "cssnano": "7.1.2",
    "cssnano-preset-default": "7.0.10",
    "date-fns": "4.1.0",
    "dotenv": "16.6.1",
    "global-agent": "3.0.0",
    "govuk-frontend": "5.14.0",
    "hapi-pino": "12.1.0",
    "hapi-pulse": "3.0.1",
    "hapi-rate-limit": "8.0.0",
    "ioredis": "5.10.0",
    "joi": "17.13.3",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.17.23",
    "node-fetch": "3.3.2",
    "node-jose": "2.2.0",
    "nunjucks": "3.2.4",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "semver": "7.7.4",
    "undici": "6.23.0",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@pact-foundation/pact": "15.0.1",
    "@stryker-mutator/core": "9.6.0",
    "@stryker-mutator/vitest-runner": "9.6.0",
    "@types/convict": "6.1.6",
    "@types/hapi__catbox-memory": "4.1.8",
    "@types/lodash": "4.17.24",
    "@types/node": "22.19.13",
    "@types/nunjucks": "3.2.6",
    "@types/webpack-assets-manifest": "5.1.4",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/eslint-plugin": "1.6.9",
    "@vitest/ui": "3.2.4",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.0.0",
    "babel-plugin-transform-import-meta": "2.3.3",
    "cheerio": "1.2.0",
    "clean-webpack-plugin": "4.0.0",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "9.1.2",
    "eslint-import-resolver-typescript": "3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "48.11.0",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "prettier": "3.8.1",
    "sass-embedded": "1.97.3",
    "sass-loader": "16.0.7",
    "snyk": "1.1303.0",
    "source-map-loader": "5.0.0",
    "stylelint": "16.26.1",
    "stylelint-config-gds": "2.0.0",
    "terser-webpack-plugin": "5.3.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "webpack": "5.105.3",
    "webpack-assets-manifest": "6.5.0",
    "webpack-cli": "6.0.1"
  }
}
